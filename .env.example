# Base URL for the ap control-plane API used by ap spawn/sessions/session commands.
AP_CONTROL_PLANE_BASE_URL=http://localhost:8080

# Optional Anthropic key to skip interactive onboarding in ap spawn.
ANTHROPIC_API_KEY=sk-ant-...

# Optional override for WorkOS client ID used during ap auth login.
AP_WORKOS_CLIENT_ID=

# Optional override for WorkOS auth domain used during ap auth login.
AP_WORKOS_AUTH_DOMAIN=
